# Base de données
DATABASE_URL=postgresql://user:password@localhost:5433/blog_db
DATABASE_URL_TEST=postgresql://user:password@localhost:5433/blog_db_test

# Auth (générer avec: openssl rand -base64 32)
JWT_SECRET=your_jwt_secret_min_32_chars_here
JWT_EXPIRES_IN=7d

# Serveur
PORT=3000
NODE_ENV=development

# Sécurité
CORS_ORIGIN=http://localhost:3000
